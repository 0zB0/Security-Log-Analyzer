APP_ENV=local
TRACEHAWK_DEPLOYMENT_PROFILE=private
AI_PROVIDER=mock
MAX_UPLOAD_BYTES=2000000
MAX_UPLOAD_LINES=100000
MAX_CASE_FILES=8
MAX_CASE_TOTAL_BYTES=8000000
ALLOWED_UPLOAD_EXTENSIONS=.log,.txt,.csv,.json,.jsonl,.xml
RATE_LIMIT_PER_MINUTE=120
PUBLIC_DEMO_MAX_BYTES=524288
PUBLIC_DEMO_MAX_LINES=20000
PUBLIC_DEMO_RATE_LIMIT_REQUESTS=5
PUBLIC_DEMO_RATE_LIMIT_WINDOW_SECONDS=600
PUBLIC_DEMO_MAX_CONCURRENCY=2
PUBLIC_DEMO_TIMEOUT_SECONDS=10
PUBLIC_DEMO_SESSION_TIMEOUT_SECONDS=1800
ALLOWED_AUTH_EMAILS=
TRACEHAWK_LLM_PROVIDER=ollama
TRACEHAWK_OLLAMA_URL=http://localhost:11434
TRACEHAWK_OLLAMA_MODEL=gpt-oss:20b
TRACEHAWK_OLLAMA_TIMEOUT_SECONDS=45
TRACEHAWK_LLM_MAX_EVIDENCE_LINES=20
TRACEHAWK_LLM_MAX_EVIDENCE_CHARS=4000
TRACEHAWK_LIVE_MAX_RAW_LINES=5000
TRACEHAWK_LIVE_MAX_EVENTS=5000
TRACEHAWK_SYSLOG_BIND_HOST=127.0.0.1
TRACEHAWK_SYSLOG_UDP_PORT=5514
TRACEHAWK_SYSLOG_TCP_PORT=5514
TRACEHAWK_SYSLOG_MAX_LINE_BYTES=8192
TRACEHAWK_SYSLOG_QUEUE_SIZE=1000
TRACEHAWK_SYSLOG_MAX_CONNECTIONS=32
TRACEHAWK_SYSLOG_IDLE_TIMEOUT_SECONDS=30
TRACEHAWK_SYSLOG_BATCH_SIZE=100
TRACEHAWK_SYSLOG_FLUSH_INTERVAL_SECONDS=1
TRACEHAWK_SYSLOG_ALLOW_REMOTE_BIND=false
TRACEHAWK_SYSLOG_STATS_INTERVAL_SECONDS=30
